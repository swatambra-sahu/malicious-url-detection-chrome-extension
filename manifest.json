{
  "manifest_version": 3,
  "name": "ThreatShield",
  "version": "1.1",
  "description": "URL Threat Detection powered by Machine Learning",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://swatambra.pythonanywhere.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
